// ─────────────────────────────────────────────────────────────────────────────
// nextflow.config  —  SLURM + Singularity
// ─────────────────────────────────────────────────────────────────────────────

params {
    // ── Inputs ──────────────────────────────────────────────────────────────
    input        = null   // path to phenotype CSV
    yaml         = null   // path to run YAML config
    genotypes    = null   // path to HMDP genotype CSV (e.g. muster_hmdp.csv.gz)
    name         = null   // run name — used as prefix for all output files
    outdir       = "results"

    // ── Input preparation ────────────────────────────────────────────────────
    downsample   = 100000 // max individuals per strain (0 = average within strain)
    maf          = 0.1    // min minor allele frequency
    missing      = 0.05   // max fraction of missing genotype calls per SNP

    // ── Container ────────────────────────────────────────────────────────────
    r_container  = null   // path to Singularity .sif with R + required packages

    // ── GWAS ────────────────────────────────────────────────────────────────
    n_traits     = 69     // number of traits (sets array job size)
    pval_thresh  = 1e-6   // significance threshold for locus definition

    // ── SuSiE ───────────────────────────────────────────────────────────────
    susie_L      = 10     // max number of causal signals per locus
    locus_window = 1e6    // locus expansion window (bp) around sig SNPs
}

// ── Executor ─────────────────────────────────────────────────────────────────
executor {
    name    = 'slurm'
    queueSize = 200
}

// ── Singularity ──────────────────────────────────────────────────────────────
singularity {
    enabled    = true
    autoMounts = true
}

// ── Process defaults ─────────────────────────────────────────────────────────
process {
    executor = 'slurm'

    // Default resources — override per process or with labels below
    cpus   = 1
    memory = '8 GB'
    time   = '2h'

    withLabel: 'low' {
        cpus   = 1
        memory = '4 GB'
        time   = '1h'
    }
    withLabel: 'medium' {
        cpus   = 4
        memory = '16 GB'
        time   = '4h'
    }
    withLabel: 'high' {
        cpus   = 8
        memory = '64 GB'
        time   = '12h'
    }
}
