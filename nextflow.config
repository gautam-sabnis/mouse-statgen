// ─────────────────────────────────────────────────────────────────────────────
// nextflow.config  —  SLURM + Singularity
// ─────────────────────────────────────────────────────────────────────────────

params {
    // ── Inputs ──────────────────────────────────────────────────────────────
    input        = null   // path to phenotype CSV
    yaml         = null   // path to run YAML config
    genotypes    = "/projects/kumar-lab/USERS/sabnig/pipes/mouse-statgen/data/muster_hmdp.csv.gz"
    name         = null   // run name — used as prefix for all output files
    outdir       = "results"

    // ── Input preparation ────────────────────────────────────────────────────
    downsample   = 100000 // max individuals per strain (0 = average within strain)
    maf          = 0.1    // min minor allele frequency
    missing      = 0.05   // max fraction of missing genotype calls per SNP
    qqnorm       = true  // QQ-normalise each phenotype before output

    // ── Container ────────────────────────────────────────────────────────────
    container    = "/projects/kumar-lab/USERS/sabnig/containers/stat-gen3.sif"

    // ── GWAS ────────────────────────────────────────────────────────────────
    n_traits     = 69     // number of traits (sets array job size)
    pval_thresh  = 1e-6   // fallback significance threshold if permutation is skipped
    perm_trait   = 1      // trait index to use for permutation threshold estimation
    n_perms      = 10   // number of permutations
    clump_r2     = 0.4    // r² threshold for LD clumping (matches rep_peaks default)
    clump_kb     = 10000  // distance window in kb for clumping (matches rep_peaks 10Mb default)

    // ── SuSiE ───────────────────────────────────────────────────────────────
    susie_L      = 10     // max number of causal signals per locus
    locus_window = 1e6    // locus expansion window (bp) around sig SNPs

    // ── Gene annotation ──────────────────────────────────────────────────────
    annot_input  = "susie"   // "susie" = credible set SNPs only; "clump" = all lead SNPs
    label_gap    = 1000      // min distance in kb between labeled loci on Manhattan plots

    // ── Peak clustering ──────────────────────────────────────────────────────
    k_clusters       = 7    // number of k-means clusters for locus clustering
    pvalthr_clusters = 5    // -log10(p) significance threshold for cluster Manhattan plots

    // ── Genetic correlations ─────────────────────────────────────────────────
    corr_traits  = "data/corr_traits.txt"      // path to txt file listing trait names (one per line);
                             // null = use all traits (n_traits choose 2 pairs)
}

// ── Executor ─────────────────────────────────────────────────────────────────
executor {
    name    = 'slurm'
    queueSize = 200
}

// ── Singularity ──────────────────────────────────────────────────────────────
singularity {
    enabled    = true
    autoMounts = true
}

// ── Process defaults ─────────────────────────────────────────────────────────
process {
    executor = 'slurm'

    // Default resources — override per process or with labels below
    cpus   = 1
    memory = '32 GB'
    time   = '2h'

    withLabel: 'low' {
        cpus   = 16
        memory = '256 GB'
        time   = '1h'
    }
    withLabel: 'medium' {
        cpus   = 32
        memory = '512 GB'
        time   = '2h'
    }
    withLabel: 'high' {
        cpus   = 32
        memory = '512 GB'
        time   = '2h'
    }
}
