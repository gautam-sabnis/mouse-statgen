Bootstrap: docker
From: rocker/tidyverse:latest

%post
    export DEBIAN_FRONTEND=noninteractive
	apt-get update
	apt-get -y install locales build-essential
	apt-get -y install python3 python3-pip git curl nano zsh wget unzip make \
	g++ libcurl4-openssl-dev libssl-dev libxml2-dev libboost-all-dev libbz2-dev libfontconfig1-dev libharfbuzz-dev libfribidi-dev \
	libfreetype6-dev libpng-dev libtiff5-dev libjpeg-dev
	pip install -U radian --break-system-packages
    locale-gen en_US.UTF-8
    update-locale LANG=en_US.UTF-8
    echo 'Etc/UTC' > /etc/timezone
    apt-get install -y libnlopt-dev
    apt-get install -y build-essential libcurl4-gnutls-dev libxml2-dev libssl-dev libgit2-dev r-base
    Rscript -e 'install.packages(c("usethis","devtools","genio"), repos="https://cran.rstudio.com")'
	Rscript -e 'library(devtools); local({r <- getOption("repos"); r["CRAN"] <- "http://cran.us.r-project.org"; options(repos=r)}); install_github("https://github.com/gautam-sabnis/mousegwas/")'
    
	# Install GEMMA
    curl -L https://github.com/genetics-statistics/GEMMA/releases/download/0.98.1/gemma-0.98.1-linux-static.gz |zcat - > /usr/local/bin/gemma
    chmod a+x /usr/local/bin/gemma
	
	#PLINK
	wget https://s3.amazonaws.com/plink1-assets/plink_linux_x86_64_20250615.zip -O /tmp/plink.zip
	unzip -o /tmp/plink.zip -d /usr/local/bin/
	chmod +x /usr/local/bin/plink
	rm /tmp/plink.zip
	
	#LDAK
	wget https://github.com/dougspeed/LDAK/raw/main/ldak6.2.linux -O /usr/local/bin/ldak
	chmod +x /usr/local/bin/ldak

	#GCTA
	wget https://yanglab.westlake.edu.cn/software/gcta/bin/gcta-1.95.1-linux-x86_64.zip -O /tmp/gcta.zip
	unzip -o /tmp/gcta.zip -d /tmp/gcta/
	cd /tmp/gcta/gcta-1.95.1-linux-x86_64/ && ./gcta64 --appimage-extract
	mv /tmp/gcta/gcta-1.95.1-linux-x86_64/squashfs-root /opt/gcta
	ln -s /opt/gcta/AppRun /usr/local/bin/gcta
	rm -rf /tmp/gcta.zip /tmp/gcta/

%apprun run_GWAS
    Rscript -e 'source(file=system.file("exec/run_GWAS_hmdp.R", package="mousegwas"))' "$@"

%apprun postprocess_mv
    Rscript -e 'source(file=system.file("exec/postprocess_mv.R", package="mousegwas"))' "$@"



%labels
    Author Gautam Sabnis & Claude Code
    Version v0.1
    Description "Singularity container for PLINK 1.9, LDAK, GCTA, and GEMMA"	
